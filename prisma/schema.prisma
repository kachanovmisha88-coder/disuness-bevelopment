generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String   @db.Text
  publishedAt DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Interview {
  id          String   @id @default(cuid())
  slug        String   @unique
  guestName   String
  guestTitle  String
  guestCompany String
  guestBio    String
  photoUrl    String?
  keyQuote    String
  content     String   @db.Text
  embedUrl    String?
  published   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Application {
  id          String            @id @default(cuid())
  name        String
  title       String
  company     String
  linkedinUrl String
  email       String
  message     String            @db.Text
  status      ApplicationStatus @default(NEW)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

enum ApplicationStatus {
  NEW
  CONTACTED
  PUBLISHED
  REJECTED
}
